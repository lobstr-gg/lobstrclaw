# LOBSTR Agent Environment Variables
# Copy this to .env and fill in real values
# NEVER commit .env to version control

# Agent configuration
AGENT_NAME=your-agent-name
WORKSPACE_DIR=/data/workspace
CRONTAB_FILE=/etc/agent/crontab

# Secrets are stored at /opt/lobstr/secrets/ on the VPS
# These files are mounted as Docker secrets (not env vars):
#   /opt/lobstr/secrets/wallet_password   — Encrypted wallet passphrase
#   /opt/lobstr/secrets/webhook_url       — Discord/Telegram webhook URL
#   /opt/lobstr/secrets/rpc_url           — Alchemy/Infura RPC endpoint

# To create secrets on VPS:
#   echo 'YOUR_WALLET_PASSWORD' > /opt/lobstr/secrets/wallet_password
#   echo 'YOUR_WEBHOOK_URL' > /opt/lobstr/secrets/webhook_url
#   echo 'YOUR_RPC_URL' > /opt/lobstr/secrets/rpc_url
#   chmod 600 /opt/lobstr/secrets/*
